# Copy to .env and replace with strong random values.
API_KEY=replace-with-openssl-rand-hex-32
FLAG_HMAC_SECRET=replace-with-openssl-rand-hex-32
SECRET_KEY=replace-with-openssl-rand-hex-32
CTFD_SECRET_KEY=replace-with-openssl-rand-hex-32

# Optional bundled CTFd image controls (setup.sh)
# CTFD_BASE_IMAGE=ctfd/ctfd:latest
# CTFD_FALLBACK_IMAGES=ctfd/ctfd:3.8.2,ctfd/ctfd:3.8.1

# Optional CTFd session lifetime (seconds). Default CTFd behavior is 7 days.
# Example below keeps users logged in for ~30 days.
# CTFD_PERMANENT_SESSION_LIFETIME=2592000
